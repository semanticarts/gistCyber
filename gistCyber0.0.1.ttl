###  https://ontologies.semanticarts.com/gist/ClientSoftware
gist:ClientSoftware rdfs:subClassOf gist:Software .


###  https://ontologies.semanticarts.com/gist/Compiler
gist:Compiler rdfs:subClassOf gist:Software .


###  https://ontologies.semanticarts.com/gist/OperatingSystem
gist:OperatingSystem rdfs:subClassOf gist:Software .


###  https://ontologies.semanticarts.com/gist/SaaS
gist:SaaS rdfs:subClassOf gist:Software .


###  https://ontologies.semanticarts.com/gist/ServerSoftware
gist:ServerSoftware rdfs:subClassOf gist:Software .


###  https://ontologies.semanticarts.com/gist/Software
gist:Software rdf:type owl:Class ;
              skos:prefLabel "Software"^^xsd:string .


###  https://ontologies.semanticarts.com/gist/SoftwareDefect
gist:SoftwareDefect rdf:type owl:Class ;
                    rdfs:subClassOf gist:Defect ;
                    skos:prefLabel "Software Defect"^^xsd:string .


###  https://ontologies.semanticarts.com/gist/SoftwareUpdate
gist:SoftwareUpdate rdfs:subClassOf gist:Software .


###  https://ontologies.semanticarts.com/gist/ThreatActor
gist:ThreatActor rdf:type owl:Class ;
                 owl:equivalentClass [ rdf:type owl:Class ;
                                       owl:unionOf ( gist:Organization
                                                     gist:Person
                                                   )
                                     ] ;
                 rdfs:subClassOf gist:Agent ;
                 skos:definition "A ThreatActor can be, or consist of, multiple persons and/or organizations"^^xsd:string ;
                 skos:prefLabel "Threat Actor"^^xsd:string .


###  https://ontologies.semanticarts.com/gist/VirtualMachine
gist:VirtualMachine rdfs:subClassOf gist:Software .


