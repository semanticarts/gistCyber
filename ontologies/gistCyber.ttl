# imports: https://w3id.org/semanticarts/ontology/gistComputing0.1.0
# imports: https://w3id.org/semanticarts/ontology/gistCore12.1.0

@prefix : <https://ontologies.semanticarts.com/o/gistCyber#> .
@prefix gist: <https://w3id.org/semanticarts/ns/ontology/gist/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/semanticarts/ontology/gistCyber>
	a owl:Ontology ;
	owl:imports
		<https://w3id.org/semanticarts/ontology/gistComputing0.1.0> ,
		<https://w3id.org/semanticarts/ontology/gistCore12.1.0>
		;
	owl:versionIRI <https://ontologies.semanticarts.com/o/gistCyberX.x.x> ;
	skos:definition "Sub-gist for cybersecurity."^^xsd:string ;
	skos:prefLabel "gistCyber"^^xsd:string ;
	.

gist:Agent
	a owl:Class ;
	.

gist:ClientSoftware
	a owl:Class ;
	rdfs:subClassOf gist:Software ;
	.

gist:Compiler
	a owl:Class ;
	rdfs:subClassOf gist:Software ;
	.

gist:ConfigurationDefect
	a owl:Class ;
	rdfs:subClassOf gist:Defect ;
	.

gist:CyberLifecycle
	a owl:Class ;
	rdfs:subClassOf gist:OrderedCollection ;
	skos:definition "The sequence of actions of a cyberattack that describe the nature and order of events from initial to final stages."^^xsd:string ;
	.

gist:CyberThreat
	a owl:Class ;
	rdfs:subClassOf gist:Threat ;
	skos:definition "A circumstance with the potential to adversely impact organizational operations, individuals, or the nation through a system via unauthorized access, destruction, disclosure, or modification of information."^^xsd:string ;
	.

gist:Defect
	a owl:Class ;
	.

gist:HardwareDefect
	a owl:Class ;
	rdfs:subClassOf gist:Defect ;
	.

gist:KillchainPhase
	a owl:Class ;
	rdfs:subClassOf gist:LifeCyclePhase ;
	.

gist:LifeCyclePhase
	a owl:Class ;
	rdfs:subClassOf gist:OrderedMember ;
	.

gist:NonadversarialThreat
	a owl:Class ;
	rdfs:subClassOf gist:Threat ;
	.

gist:OperatingSystem
	a owl:Class ;
	rdfs:subClassOf gist:Software ;
	.

gist:Procedure
	a owl:Class ;
	.

gist:Risk
	a owl:Class ;
	.

gist:SaaS
	a owl:Class ;
	rdfs:subClassOf gist:Software ;
	.

gist:ServerSoftware
	a owl:Class ;
	rdfs:subClassOf gist:Software ;
	.

gist:Software
	a owl:Class ;
	skos:prefLabel "Software"^^xsd:string ;
	.

gist:SoftwareDefect
	a owl:Class ;
	rdfs:subClassOf gist:Defect ;
	skos:prefLabel "Software Defect"^^xsd:string ;
	.

gist:SoftwareUpdate
	a owl:Class ;
	rdfs:subClassOf gist:Software ;
	.

gist:Tactic
	a owl:Class ;
	.

gist:Technique
	a owl:Class ;
	.

gist:Threat
	a owl:Class ;
	skos:definition "A circumstance with the potential to adversely impact organizational operations, individuals, or the nation"^^xsd:string ;
	.

gist:ThreatActor
	a owl:Class ;
	rdfs:subClassOf gist:Agent ;
	owl:equivalentClass [
		a owl:Class ;
		owl:unionOf (
			gist:Organization
			gist:Person
		) ;
	] ;
	skos:definition "Threat Actors are individuals, groups, or organizations believed to be operating with malicious intent."^^xsd:string ;
	skos:prefLabel "Threat Actor"^^xsd:string ;
	.

gist:ThreatLifecycle
	a owl:Class ;
	rdfs:subClassOf gist:CyberLifecycle ;
	.

gist:VirtualMachine
	a owl:Class ;
	rdfs:subClassOf gist:Software ;
	.

gist:Vulnerability
	a owl:Class ;
	rdfs:subClassOf gist:SoftwareDefect ;
	.

